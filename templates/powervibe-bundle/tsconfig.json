{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "jsx": "preserve",
    "types": ["node"],
    "paths": {
      "@/*": ["../../app/src/*"],
      "@shared/*": ["../../shared/*"]
    }
  },
  "include": ["./**/*.ts", "./**/*.vue"]
}
