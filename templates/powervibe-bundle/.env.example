# PowerVibe per-app bundle — Apply writes `bundles/<appId>/.env` with:
#   • Redis / Scribe / DATABASE_URL (and all SCRIBE_*) copied from the repo-root `.env` when present, else sensible local defaults
#   • Enforced bundle Flight keys (port 4000, production, etc.)
# Add per-app overrides here (GEMINI_*, VITE_*, …).

FLIGHT_PORT=4000
FLIGHT_MODE=production
FLIGHT_DIST_PATH=./dist
# Pre-build with `vite build` before starting Flight; skip Flight’s async `npx vite build` (see powervibeBundleRunner).
FLIGHT_DISABLE_VITE=true
# Always 1 for bundle Flight — avoids multiple workers binding the same port during switches.
FLIGHT_MAX_WORKERS=1
FLIGHT_SESSION_DURATION_MS=86400000
FLIGHT_REDIS_HOST=127.0.0.1
FLIGHT_REDIS_PORT=6379
# Optional: match workspace for large saves
# FLIGHT_PAYLOAD_LIMIT=64mb

# SCRIBE_URL=http://127.0.0.1:1337
# VITE_* — available at `vite build` for the generated app shell
