{
  "name": "powervibe-poc",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/thoughtpivot/powervibe.git"
  },
  "type": "module",
  "scripts": {
    "postinstall": "patch-package",
    "start:docker": "docker compose up -d",
    "start:app": "dotenv -e .env -- node --disable-warning=DEP0040 ./node_modules/tsx/dist/cli.mjs -r tsconfig-paths/register node_modules/@spytech/flight/src/flight.ts --mode development .",
    "start:slides": "dotenv -e .env -- slidev slides/slides.md --port 3030",
    "typecheck": "vue-tsc -p app/tsconfig.app.json --noEmit && tsc -p tsconfig.backend.json --noEmit",
    "test:powervibe-scribe-components": "tsx --test -r tsconfig-paths/register app/src/components/powervibe/apps/powervibeAppScribeComponents.test.ts",
    "powervibe:smoke": "node scripts/powervibe-smoke.mjs",
    "powervibe:prompt-invariants": "node scripts/powervibe-prompt-invariants.mjs",
    "powervibe:guards": "npm run powervibe:prompt-invariants && tsx --test -r tsconfig-paths/register app/src/components/powervibe/viewer/powervibeAppBackendForFlight.test.ts",
    "powervibe:push-backend-scribe": "dotenv -e .env -- node --disable-warning=DEP0040 ./node_modules/tsx/dist/cli.mjs -r tsconfig-paths/register scripts/pushPowervibeBackendToScribe.ts",
    "powervibe:randomize-icons": "dotenv -e .env -- node --disable-warning=DEP0040 ./node_modules/tsx/dist/cli.mjs -r tsconfig-paths/register app/src/components/powervibe/apps/randomizePowervibeAppIcons.script.ts",
    "build:app": "dotenv -e .env -- vite build --config app/vite.config.ts",
    "build:slides:pdf": "slidev export slides/slides.md --format pdf --output docs/powervibe-board-slides.pdf --dark"
  },
  "dependencies": {
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.2",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@google/genai": "^1.50.1",
    "@headlessui/vue": "^1.7.23",
    "@heroicons/vue": "^2.2.0",
    "@koa/bodyparser": "^6.1.0",
    "@koa/router": "^15.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@phosphor-icons/vue": "^2.2.1",
    "@shikijs/markdown-it": "^4.0.2",
    "@thoughtpivot/flight": "^1.0.7",
    "@vueuse/core": "^12.8.2",
    "axios": "^1.15.2",
    "chart.js": "^4.5.1",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "codemirror": "^6.0.2",
    "dompurify": "^3.4.1",
    "dotenv": "^17.4.2",
    "i": "^0.3.7",
    "ioredis": "^5.8.2",
    "jsonrepair": "^3.14.0",
    "koa": "^3.1.1",
    "lucide-vue-next": "^0.503.0",
    "markdown-it": "^14.1.1",
    "npm": "^11.13.0",
    "pg": "^8.20.0",
    "reka-ui": "^2.6.0",
    "shiki": "^4.0.2",
    "tailwind-merge": "^3.3.1",
    "vue": "^3.5.13",
    "vue-chartjs": "^5.3.3",
    "vue-codemirror": "^6.1.1",
    "vue-router": "^5.0.6",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@slidev/cli": "^52.14.2",
    "@slidev/theme-default": "^0.25.0",
    "@tailwindcss/vite": "^4.1.11",
    "@types/dompurify": "^3.0.5",
    "@types/koa": "^3.0.2",
    "@types/koa__router": "^12.0.4",
    "@types/koa-bodyparser": "^4.3.13",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.15.3",
    "@types/pg": "^8.20.0",
    "@vitejs/plugin-vue": "^6.0.1",
    "daisyui": "^5.0.50",
    "dotenv-cli": "^11.0.0",
    "patch-package": "^8.0.1",
    "playwright-chromium": "^1.59.1",
    "sass": "^1.99.0",
    "tailwindcss": "^4.1.11",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "~5.8.3",
    "unplugin-icons": "^22.1.0",
    "vite": "^7.0.6",
    "vue-tsc": "^2.2.12"
  },
  "overrides": {
    "@thoughtpivot/flight": {
      "koa": "^3.1.1"
    }
  }
}
