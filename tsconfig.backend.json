{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "verbatimModuleSyntax": true,
    "allowImportingTsExtensions": true,
    "types": ["node", "koa-bodyparser"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["app/src/*"],
      "@shared/*": ["shared/*"]
    },
    "resolveJsonModule": true
  },
  "include": [
    "app/src/**/*.backend.ts",
    "app/src/lib/scribe.ts",
    "app/src/components/kota0/ai/plan/planRun.ts",
    "app/src/components/kota0/ai/plan/kota0IdeationRun.ts",
    "app/src/components/kota0/apps/ScribeKota0AppRepository.ts",
    "app/src/components/kota0/apps/kota0AppScribeComponents.ts",
    "app/src/components/kota0/apps/kota0AppScribeComponents.test.ts",
    "app/src/components/kota0/ai/ScribeKota0ChatRepository.ts",
    "app/src/components/kota0/ai/scribeKota0History.ts",
    "app/src/components/kota0/ai/scribeKota0RevisionActivity.ts",
    "app/src/components/kota0/viewer/kota0Materialize.ts",
    "app/src/components/kota0/deploy/**/*.ts",
    "app/src/components/kota0/viewer/kota0SfcTailwindSanitize.ts",
    "app/src/components/kota0/ai/kota0ChatTypes.ts",
    "app/src/components/kota0/ai/kota0ChatForModel.ts",
    "app/src/components/kota0/viewer/kota0AppBackendForFlight.ts",
    "app/src/components/kota0/viewer/kota0AppBackendForFlight.test.ts",
    "app/src/components/kota0/viewer/kota0WorkspaceDepsSummary.ts",
    "app/src/components/kota0/viewer/kota0SfcHeadOutline.ts",
    "app/src/lib/geminiModel.ts",
    "app/src/components/kota0/ai/geminiTranscribeAudio.ts",
    "app/src/components/kota0/ai/kota0WorkspaceAiCompletion.ts",
    "app/src/components/kota0/ai/kota0WorkspaceAiCompletion.test.ts",
    "app/src/components/kota0/apps/kota0AppTypes.ts",
    "app/src/components/kota0/apps/kota0AppIconIds.ts",
    "app/src/components/kota0/apps/kota0AppIconRandom.ts",
    "app/src/components/kota0/apps/randomizeKota0AppIcons.script.ts",
    "app/src/components/kota0/ai/chat.types.ts",
    "shared/**/*.ts",
    "scripts/pushKota0BackendToScribe.ts",
    "scripts/start-scribe-gateway.ts",
    "app/src/components/kota0/gateway/**/*.ts"
  ],
  "exclude": [
    "app/src/components/kota0/deploy/kota0DeployApi.ts",
    "app/src/components/kota0/deploy/Kota0DeployPanel.vue"
  ]
}
