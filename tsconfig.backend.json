{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "verbatimModuleSyntax": true,
    "allowImportingTsExtensions": true,
    "types": ["node", "koa-bodyparser"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["app/src/*"],
      "@shared/*": ["shared/*"]
    },
    "resolveJsonModule": true
  },
  "include": [
    "app/src/**/*.backend.ts",
    "app/src/lib/scribe.ts",
    "app/src/components/powervibe/ai/plan/planRun.ts",
    "app/src/components/powervibe/ai/plan/powervibeIdeationRun.ts",
    "app/src/components/powervibe/apps/ScribePowervibeAppRepository.ts",
    "app/src/components/powervibe/ai/ScribePowervibeChatRepository.ts",
    "app/src/components/powervibe/ai/scribePowervibeHistory.ts",
    "app/src/components/powervibe/ai/scribePowervibeRevisionActivity.ts",
    "app/src/components/powervibe/viewer/powervibeMaterialize.ts",
    "app/src/components/powervibe/deploy/**/*.ts",
    "app/src/components/powervibe/viewer/powervibeSfcTailwindSanitize.ts",
    "app/src/components/powervibe/ai/powervibeChatTypes.ts",
    "app/src/components/powervibe/ai/powervibeChatForModel.ts",
    "app/src/components/powervibe/viewer/powervibeWorkspaceDepsSummary.ts",
    "app/src/components/powervibe/viewer/powervibeSfcHeadOutline.ts",
    "app/src/lib/geminiModel.ts",
    "app/src/components/powervibe/apps/powervibeAppTypes.ts",
    "app/src/components/powervibe/apps/powervibeAppIconIds.ts",
    "app/src/components/powervibe/apps/powervibeAppIconRandom.ts",
    "app/src/components/powervibe/apps/randomizePowervibeAppIcons.script.ts",
    "app/src/components/powervibe/ai/chat.types.ts",
    "shared/**/*.ts"
  ]
}
